{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "selected_specialists": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of specialist agent names to invoke"
    },
    "reasoning": {
      "type": "string",
      "description": "Reasoning for why these specialists were selected"
    },
    "estimated_complexity": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Estimated complexity"
    },
    "suggested_phases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Suggested workflow phases to execute"
    }
  },
  "required": ["selected_specialists", "reasoning", "estimated_complexity", "suggested_phases"]
}
