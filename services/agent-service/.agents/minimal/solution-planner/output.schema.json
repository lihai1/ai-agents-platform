{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "description": "High-level description of the implementation"
    },
    "files_expected_to_change": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of files that will be modified or created"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of acceptance criteria for the implementation"
    },
    "estimated_steps": {
      "type": "integer",
      "description": "Estimated number of implementation steps"
    },
    "risk_factors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Potential risks or challenges"
    },
    "suggested_approach": {
      "type": "string",
      "description": "Suggested approach for implementation"
    },
    "dependencies_to_add": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "New dependencies that may need to be added"
    },
    "tests_to_write": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tests that should be written"
    }
  },
  "required": ["description", "files_expected_to_change", "acceptance_criteria", "estimated_steps", "risk_factors", "suggested_approach", "tests_to_write"]
}
